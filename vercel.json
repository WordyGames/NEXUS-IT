{
  "installCommand": "npm install",
  "buildCommand": "npm run build --workspace=apps/desktop",
  "outputDirectory": "apps/desktop/dist/renderer",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
